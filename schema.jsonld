  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How close is Kimba Lodge to Kruger National Park?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kimba Lodge is less than 2 km from the Phalaborwa Gate of Kruger National Park."
        }
      },
      {
        "@type": "Question",
        "name": "How do I book a room at Kimba Lodge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can book via the 'Book Now' button on the Rooms or Contact page, or contact us directly via WhatsApp at +27 84 909 1777 or email info@kimbalodge.co.za."
        }
      },
      {
        "@type": "Question",
        "name": "What is the cancellation policy at Kimba Lodge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Free cancellation is available up to 7 days before arrival. A 50% deposit is required at booking; the balance is due on arrival."
        }
      },
      {
        "@type": "Question",
        "name": "Is Wi-Fi available at Kimba Lodge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, free high-speed Wi-Fi is available throughout the lodge."
        }
      },
      {
        "@type": "Question",
        "name": "What activities are available near Kimba Lodge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Activities include guided game drives, walking safaris, river safaris, Kruger Park day trips, cultural visits, and golf at the Hans Merensky Golf Course (500 m from the lodge)."
        }
      },
      {
        "@type": "Question",
        "name": "Are children welcome at Kimba Lodge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, children of all ages are welcome. Kimba Lodge has family-friendly rooms including the Lion and Cubs Suite and the Baobab Cottage, as well as a dedicated children's play cottage."
        }
      }
    ]
  },
